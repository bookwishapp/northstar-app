# Database (Railway PostgreSQL)
# Railway will auto-inject this for the Postgres service
DATABASE_URL=postgresql://postgres:password@localhost:5432/railway

# Railway Internal Service URLs
# This is the internal URL for Gotenberg service within Railway
GOTENBERG_URL=http://northstar-gotenberg.railway.internal:3000

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=northstar-postal

# OpenAI API
OPENAI_API_KEY=your_openai_api_key

# PostGrid API (Physical Mail)
POSTGRID_API_KEY=your_postgrid_api_key

# Application Configuration
NEXT_PUBLIC_BASE_URL=https://pretty-purpose.up.railway.app
ADMIN_SESSION_SECRET=your_random_32_character_session_secret_here

# Future Integrations (not needed for initial setup)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Railway Environment
RAILWAY_ENVIRONMENT=production