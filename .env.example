# Database (Railway PostgreSQL)
# Railway will auto-inject this for the Postgres service
DATABASE_URL=postgresql://postgres:password@localhost:5432/railway

# Railway Internal Service URLs
# This is the internal URL for Gotenberg service within Railway
GOTENBERG_URL=http://northstar-gotenberg.railway.internal:3000

# AWS Configuration (Required - Set in Railway)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_S3_BUCKET=your_s3_bucket_name_here

# AI Configuration (at least one API key required)
# Primary: Anthropic (Claude) - Better for creative writing
ANTHROPIC_API_KEY=your_anthropic_api_key
# Optional: Specify model (default: claude-sonnet-4-6)
# Options: claude-sonnet-4-6, claude-haiku-4-5-20251001, claude-opus-4-6
ANTHROPIC_MODEL=claude-sonnet-4-6

# Fallback: OpenAI (GPT) - Used if Anthropic fails or is not configured
OPENAI_API_KEY=your_openai_api_key
# Optional: Specify model (default: gpt-4o)
# Options: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-4-turbo-preview, gpt-4
OPENAI_MODEL=gpt-4o

# PostGrid API (Physical Mail)
POSTGRID_API_KEY=your_postgrid_api_key

# Application Configuration
NEXT_PUBLIC_BASE_URL=https://pretty-purpose.up.railway.app
ADMIN_SESSION_SECRET=your_random_32_character_session_secret_here
# Primary domain for redirects (use www.yourdomain.com or yourdomain.com)
PRIMARY_DOMAIN=www.northstarpostal.com

# Auth (NextAuth)
AUTH_SECRET=generate_with_openssl_rand_base64_32

# Email Settings (Required - uses AWS SES)
# FROM_EMAIL must be verified in AWS SES
FROM_EMAIL=your_verified_email@yourdomain.com
FROM_NAME=North Star Postal

# Future Integrations (not needed for initial setup)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Railway Environment
RAILWAY_ENVIRONMENT=production